{
  "manifest_version": 3,
  "name": "AppTrail",
  "short_name": "AppTrail",
  "version": "1.0.0",
  "description": "Job application tracking — capture, contacts, and pipeline management",
  "homepage_url": "https://apptrail.com",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://api.apptrail.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "https://boards.greenhouse.io/*",
    "https://boards-api.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://api.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.myworkday.com/*",
    "https://jobs.ashbyhq.com/*",
    "https://www.indeed.com/*",
    "https://*.indeed.com/*",
    "https://www.linkedin.com/*",
    "https://www.glassdoor.com/*",
    "https://www.ziprecruiter.com/*",
    "https://wellfound.com/*",
    "https://jobs.smartrecruiters.com/*",
    "https://*.icims.com/*",
    "https://jobs.jobvite.com/*",
    "https://app.jobvite.com/*",
    "https://talent.jobvite.com/*",
    "https://*.bamboohr.com/*",
    "https://ats.rippling.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://jobs.lever.co/*/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.myworkday.com/*",
        "https://jobs.ashbyhq.com/*/*",
        "https://www.indeed.com/viewjob*",
        "https://www.indeed.com/rc/clk*",
        "https://www.indeed.com/jobs*",
        "https://*.indeed.com/viewjob*",
        "https://*.indeed.com/jobs*",
        "https://www.glassdoor.com/job-listing/*",
        "https://www.glassdoor.com/Job/*",
        "https://www.glassdoor.com/Jobs/*",
        "https://www.ziprecruiter.com/c/*/Job/*",
        "https://wellfound.com/company/*/jobs/*",
        "https://jobs.smartrecruiters.com/*/*",
        "https://*.icims.com/jobs/*/job",
        "https://jobs.jobvite.com/*/*",
        "https://*.bamboohr.com/careers/*",
        "https://ats.rippling.com/*/jobs/*"
      ],
      "js": ["content.js", "banner.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*/*careers*",
        "https://*/*jobs*",
        "https://*/*job-openings*",
        "https://*/*opportunities*",
        "https://*/*work-with-us*",
        "https://*/*join-us*"
      ],
      "js": ["tracker.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AppTrail",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
