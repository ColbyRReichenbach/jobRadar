# Generated eval/artifact outputs stay local; source datasets, runners, and
# changelog docs are committed separately.
docs/interview-artifacts/generated/**
!docs/interview-artifacts/generated/
!docs/interview-artifacts/generated/.gitkeep

# Rendered reports are local/share artifacts; commit Markdown/source scripts
# instead so PDFs/HTML can be regenerated without bloating the repo.
docs/interview-artifacts/**/*.html
docs/interview-artifacts/**/*.pdf
docs/interview-artifacts/**/*production-decision-report.txt

