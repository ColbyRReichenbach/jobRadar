# ==============================================================================
# AppTrail — Environment Variables
# Copy this file to .env and fill in all values before starting each phase.
# For local development, prefer `make local-env`; it creates `.env.local`, which
# backend commands load ahead of `.env` so hosted databases are not woken by
# manual testing.
# NEVER commit .env to git. Verify .gitignore contains ".env" before first push.
# ==============================================================================

# ------------------------------------------------------------------------------
# PHASE 1 REQUIRED — Must be set before starting Phase 1
# ------------------------------------------------------------------------------

# Local Postgres. `make local-env` writes this to `.env.local` automatically.
# Put hosted Neon URLs in production/Railway env vars, not local dev env files,
# unless you are intentionally testing against the hosted database.
DATABASE_URL=postgresql+asyncpg://apptrail:apptrail@localhost:5432/apptrail
NEON_DATABASE_URL=

# JWT signing secret — generate a unique random value per environment.
# Example: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# OpenAI — from platform.openai.com → API Keys
# Used for classification, drafting, resume parsing/tailoring, and Radar.
OPENAI_API_KEY=sk-...

# Extension API keys are generated per user in the dashboard Settings page.
# Do not configure a shared production extension key in environment variables.

# App environment
ENVIRONMENT=development
# Change to "production" before deploying. Controls CORS origins and logging level.

# Minimum distinct users required before product-wide company/ATS intelligence is shown.
APPTRAIL_AGGREGATE_MIN_USERS=3

# Radar launch controls.
# Keep false in idle/non-beta environments to disable Radar API access and
# scheduled dispatch.
RADAR_ENABLED=false
# Increase this in constrained environments to reduce scheduled Neon wakeups.
RADAR_DISPATCH_INTERVAL_SECONDS=900
# In production, public-web research and hybrid trackers require this to be true.
RADAR_RESEARCH_ENABLED=false
# Max Radar alerts a single user can receive in a rolling 24-hour window. Set 0 to suppress.
RADAR_ALERT_MAX_PER_USER_PER_DAY=5

# AI platform controls planned for Copilot, Search, evals, and governance.
# Keep Copilot off until the backend, frontend, eval, and admin telemetry gates are green.
COPILOT_ENABLED=false
COPILOT_DAILY_COST_CAP_CENTS_PER_USER=50
COPILOT_GLOBAL_DAILY_COST_CAP_CENTS=5000
COPILOT_MAX_REQUESTS_PER_MINUTE=10
COPILOT_MAX_CONTEXT_DOCS=8
COPILOT_MAX_CONTEXT_TOKENS=12000
COPILOT_MAX_MESSAGE_CHARS=4000
COPILOT_MAX_CONVERSATION_MESSAGES=40
COPILOT_SHADOW_TEST_RATE=0.10
COPILOT_EXPERIMENTS_ENABLED=false

# Search defaults to Postgres so local development and CI do not require OpenSearch.
SEARCH_BACKEND=postgres
OPENSEARCH_URL=
SEARCH_OPENSEARCH_FALLBACK_TO_POSTGRES=true

# AI trace and report governance.
AI_TRACE_FULL_PAYLOADS_ENABLED=false
AI_FULL_TRACE_EXPORT_ENABLED=false
AI_TRACE_RETENTION_DAYS=30
AI_PROMOTION_REPORT_MIN_CALLS=1000
AI_PROMOTION_REPORT_MIN_FEEDBACK=50
AI_MODEL_PRICING_CONFIG=
AI_REPORT_OUTPUT_DIR=docs/interview-artifacts/generated
AI_REPORT_PROGRESS_INDEX=docs/interview-artifacts/ai-system-progress-over-time.md

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Keep public liveness checks cheap. `/api/health` does not touch external
# services unless these are enabled. Use `/api/ready` for deploy readiness.
HEALTH_CHECK_DATABASE=false
HEALTH_CHECK_REDIS=false

# ------------------------------------------------------------------------------
# PHASE 2 REQUIRED — Add before starting Phase 2
# ------------------------------------------------------------------------------

# Hunter.io — from hunter.io/api-keys
# Free tier: 25 searches/month. Results cached per domain for 30 days.
HUNTER_API_KEY=

# ------------------------------------------------------------------------------
# PHASE 3 REQUIRED — Add before starting Phase 3
# ------------------------------------------------------------------------------

# Upstash Redis — from console.upstash.com → your database → .env tab
# Celery broker + Beat schedule persistence
REDIS_URL=rediss://default:[PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379

# Master switch for Celery beat jobs that open database sessions. Keep false in
# idle/non-beta environments to let Neon scale to zero.
SCHEDULED_DB_JOBS_ENABLED=false

# Gmail polling runs through Celery beat and opens a database session each interval.
# Disable or raise the interval in idle/beta environments to reduce Neon compute.
GMAIL_POLLING_ENABLED=false
GMAIL_POLL_INTERVAL_SECONDS=3600

# Gmail OAuth2 — from console.cloud.google.com
# Steps: Create project → Enable Gmail API → Credentials → OAuth2 Client ID (Desktop app)
# Download the JSON, extract client_id and client_secret
GMAIL_CLIENT_ID=[YOUR-CLIENT-ID].apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...

# Gmail OAuth redirect URI — for local dev
# Register this exact URI in Google Cloud Console under your OAuth2 client
GMAIL_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# Google OAuth redirect URI for user sign-in — also register in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Gmail classifier rollout mode:
# - hybrid_dry_run: local NLP/rules path only, no LLM calls
# - hybrid: local NLP/rules path plus preflight-gated LLM adjudication for ambiguous cases
# - legacy: previous LLM-first classifier path
GMAIL_CLASSIFIER_MODE=hybrid_dry_run

# Gmail sync scanning controls. The API accepts any positive max_messages value,
# then clamps to this hard ceiling to avoid accidental runaway syncs.
APPTRAIL_GMAIL_SYNC_DAYS=90
APPTRAIL_GMAIL_SYNC_MAX_MESSAGES=250
APPTRAIL_GMAIL_SYNC_HARD_MAX_MESSAGES=5000

# ------------------------------------------------------------------------------
# PHASE 4 REQUIRED — Add before starting Phase 4
# ------------------------------------------------------------------------------

# SerpAPI — from serpapi.com/manage-api-key
# $50/mo plan for Google Jobs search. Cache results 24h to minimize cost.
SERPAPI_KEY=

# Dashboard URL — your Vercel deployment URL after first deploy
# Used for CORS allowlist in production FastAPI config
# Example: https://apptrail.vercel.app
DASHBOARD_URL=

# Additional exact browser origins allowed to call the API with credentials.
# Comma-separate staging or reviewed preview origins. Wildcard Vercel previews are not allowed.
CORS_ALLOWED_ORIGINS=
VERCEL_PREVIEW_ORIGINS=

# Published Chrome extension ID. Required for extension CORS in production.
CHROME_EXTENSION_ID=

# Chrome Extension — Chrome Web Store listing URL (set after publishing)
# Displayed in the dashboard Settings page as an install link for users
# Example: https://chromewebstore.google.com/detail/apptrail/abcdefghijklmnop
VITE_CHROME_EXTENSION_URL=

# Dashboard feature flags. Keep Copilot hidden until backend, frontend, eval, and admin telemetry gates are green.
VITE_COPILOT_ENABLED=false
# Background dashboard polling interval. In production, the frontend defaults to
# one initial load only unless this is set to a positive number.
VITE_DASHBOARD_POLL_INTERVAL_SECONDS=0

# ------------------------------------------------------------------------------
# PRODUCTION ONLY — Set in Railway/Render dashboard, not in .env file
# These are here for documentation. Do not put real production values in this file.
# ------------------------------------------------------------------------------

# Production database — Neon pooled connection string.
# DATABASE_URL=postgresql+asyncpg://neondb_owner:[PASSWORD]@[PROJECT]-pooler.[REGION].aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Production CORS — update after Vercel deploy
# DASHBOARD_URL=https://your-app.vercel.app
# CORS_ALLOWED_ORIGINS=https://app.apptrail.com
# CHROME_EXTENSION_ID=abcdefghijklmnopabcdefghijklmnop

# Production admin users and metrics protection
# APPTRAIL_ADMIN_EMAILS=founder@apptrail.com,ops@apptrail.com
# METRICS_BEARER_TOKEN=replace-with-random-token

# Production readiness checks
# Keep false for uptime monitors and platform liveness probes to avoid waking Neon.
# Use /api/ready for deploy smoke checks that intentionally validate dependencies.
# HEALTH_CHECK_DATABASE=false
# HEALTH_CHECK_REDIS=false
# READINESS_REQUIRE_CELERY=true
# CELERY_BEAT_MAX_AGE_SECONDS=180
# CELERY_READINESS_TIMEOUT_SECONDS=1.0

# AI platform production posture
# COPILOT_ENABLED=false
# COPILOT_EXPERIMENTS_ENABLED=false
# COPILOT_MAX_MESSAGE_CHARS=4000
# COPILOT_MAX_CONVERSATION_MESSAGES=40
# AI_TRACE_FULL_PAYLOADS_ENABLED=false
# AI_FULL_TRACE_EXPORT_ENABLED=false
# AI_TRACE_RETENTION_DAYS=30
# SEARCH_BACKEND=postgres
# SEARCH_OPENSEARCH_FALLBACK_TO_POSTGRES=true

# Railway/Render automatically injects PORT — do not hardcode in production
# BACKEND_PORT is ignored in production; Railway uses its own port injection

# ------------------------------------------------------------------------------
# OPTIONAL — Logging and debug settings
# ------------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to true to print all SQL queries (useful for debugging slow queries)
SQLALCHEMY_ECHO=false

# Source-intelligence verification is disabled by default until direct-source
# search is ready for active use.
JOB_SOURCE_VERIFICATION_BEAT_ENABLED=false
SOURCE_VERIFICATION_INTERVAL_SECONDS=3600

# Playwright: set to true to run browser in headed mode for debugging scrapers
PLAYWRIGHT_HEADLESS=true

# ==============================================================================
# QUICK REFERENCE — Where to get each key
# ==============================================================================
#
# DATABASE_URL          Local Postgres for dev; Neon pooled URI in production
# NEON_DATABASE_URL     Production deploy helper only; Neon pooled URI
# JWT_SECRET            python -c "import secrets; print(secrets.token_urlsafe(48))"
# OPENAI_API_KEY        platform.openai.com → API Keys
# HUNTER_API_KEY        hunter.io/api-keys
# REDIS_URL             Railway Redis or managed Redis URL
# GMAIL_CLIENT_ID       console.cloud.google.com → APIs → Credentials → OAuth2
# GMAIL_CLIENT_SECRET   same as above
# SERPAPI_KEY           serpapi.com/manage-api-key
#
# ==============================================================================
