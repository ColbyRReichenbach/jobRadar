# ==============================================================================
# AppTrail — Environment Variables
# Copy this file to .env and fill in all values before starting each phase.
# NEVER commit .env to git. Verify .gitignore contains ".env" before first push.
# ==============================================================================

# ------------------------------------------------------------------------------
# PHASE 1 REQUIRED — Must be set before starting Phase 1
# ------------------------------------------------------------------------------

# Supabase — from your project at supabase.com/dashboard
# Project Settings → Database → Connection String (use the "asyncpg" URI format)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase — Project Settings → API → service_role key (NOT the anon key)
# Used server-side only. Never expose to extension or browser.
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic — from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# AppTrail API Key — generated once, used to authenticate the Chrome extension to the backend
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Store the output here AND paste it into the extension setup page on first install
APPTRAIL_API_KEY=

# App environment
ENVIRONMENT=development
# Change to "production" before deploying. Controls CORS origins and logging level.

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ------------------------------------------------------------------------------
# PHASE 2 REQUIRED — Add before starting Phase 2
# ------------------------------------------------------------------------------

# Hunter.io — from hunter.io/api-keys
# Free tier: 25 searches/month. Results cached per domain for 30 days.
HUNTER_API_KEY=

# ------------------------------------------------------------------------------
# PHASE 3 REQUIRED — Add before starting Phase 3
# ------------------------------------------------------------------------------

# Upstash Redis — from console.upstash.com → your database → .env tab
# Celery broker + Beat schedule persistence
REDIS_URL=rediss://default:[PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379

# Gmail OAuth2 — from console.cloud.google.com
# Steps: Create project → Enable Gmail API → Credentials → OAuth2 Client ID (Desktop app)
# Download the JSON, extract client_id and client_secret
GMAIL_CLIENT_ID=[YOUR-CLIENT-ID].apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...

# Gmail OAuth redirect URI — for local dev
# Register this exact URI in Google Cloud Console under your OAuth2 client
GMAIL_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# Google OAuth redirect URI for user sign-in — also register in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ------------------------------------------------------------------------------
# PHASE 4 REQUIRED — Add before starting Phase 4
# ------------------------------------------------------------------------------

# SerpAPI — from serpapi.com/manage-api-key
# $50/mo plan for Google Jobs search. Cache results 24h to minimize cost.
SERPAPI_KEY=

# Dashboard URL — your Vercel deployment URL after first deploy
# Used for CORS allowlist in production FastAPI config
# Example: https://apptrail.vercel.app
DASHBOARD_URL=

# ------------------------------------------------------------------------------
# PRODUCTION ONLY — Set in Railway/Render dashboard, not in .env file
# These are here for documentation. Do not put real production values in this file.
# ------------------------------------------------------------------------------

# Production database — Supabase connection pooler URL (port 6543, not 5432)
# Project Settings → Database → Connection Pooling → Connection String
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:6543/postgres?pgbouncer=true

# Production CORS — update after Vercel deploy
# DASHBOARD_URL=https://your-app.vercel.app

# Railway/Render automatically injects PORT — do not hardcode in production
# BACKEND_PORT is ignored in production; Railway uses its own port injection

# ------------------------------------------------------------------------------
# OPTIONAL — Logging and debug settings
# ------------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to true to print all SQL queries (useful for debugging slow queries)
SQLALCHEMY_ECHO=false

# Playwright: set to true to run browser in headed mode for debugging scrapers
PLAYWRIGHT_HEADLESS=true

# ==============================================================================
# QUICK REFERENCE — Where to get each key
# ==============================================================================
#
# DATABASE_URL          supabase.com → Project → Settings → Database → URI
# SUPABASE_URL          supabase.com → Project → Settings → API → Project URL
# SUPABASE_SERVICE_ROLE supabase.com → Project → Settings → API → service_role
# ANTHROPIC_API_KEY     console.anthropic.com → API Keys
# APPTRAIL_API_KEY      python -c "import secrets; print(secrets.token_hex(32))"
# HUNTER_API_KEY        hunter.io/api-keys
# REDIS_URL             console.upstash.com → Database → .env tab (use TLS URL)
# GMAIL_CLIENT_ID       console.cloud.google.com → APIs → Credentials → OAuth2
# GMAIL_CLIENT_SECRET   same as above
# SERPAPI_KEY           serpapi.com/manage-api-key
#
# ==============================================================================
