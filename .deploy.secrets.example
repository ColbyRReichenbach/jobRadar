# Local deployment secrets template.
# Copy to .deploy.secrets.local and fill values locally. Never commit real secrets.

# Provider tokens
NEON_API_KEY=
VERCEL_TOKEN=
RAILWAY_API_TOKEN=

# App database
# Prefer Neon's pooled connection string for production app traffic.
# Convert postgresql:// to postgresql+asyncpg:// for this FastAPI backend.
NEON_DATABASE_URL=

# Required app integrations
OPENAI_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Deployment URLs, filled after provider services exist
DASHBOARD_URL=
API_URL=
GOOGLE_REDIRECT_URI=

# Optional integrations
HUNTER_API_KEY=
SERPAPI_KEY=
SENTRY_DSN=
